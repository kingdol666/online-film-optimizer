      "exploit": { "before": { "minStableTicks": 6, "maxTicks": 30 }, "after": { "minStableTicks": 6, "maxTicks": 30 } },
      "recover": { "before": { "minStableTicks": 5, "maxTicks": 30 }, "after": { "minStableTicks": 5, "maxTicks": 30 } }
    }
  }
}
