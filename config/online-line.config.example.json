{
  "ports": {
    "backend": 4317,
    "frontend": 5418,
    "simulator": 8877
  },
  "orchestrator": {
    "provider": "real-line",
    "execution_mode": "semi_auto",
    "auto_approve_simulator": true,
    "max_consecutive_worse": 2,
    "hooks": {
      "approval": "online-bridge",
      "inspection": "online-bridge",
      "historian": "online-bridge",
      "write": "online-bridge",
      "safety": "online-bridge",
      "reporting": "local-filesystem"
    }
  },
  "online": {
    "enabled": true,
    "line_id": "bopet-pilot-line-01",
    "ws_url": "ws://127.0.0.1:19081/ws/online-line",
    "http_url": "http://127.0.0.1:19081",
    "historian_url": "http://127.0.0.1:19082",
    "db_url": "postgres://readonly:readonly@127.0.0.1:5432/line_historian",
    "timeout_ms": 10000,
    "reconnect_ms": 3000,
    "require_online": false,
    "hooks": {
      "inspection": "websocket",
      "historian": "websocket",
      "approval": "websocket",
      "write": "websocket",
      "safety": "websocket",
      "database": "websocket"
    },
    "tag_map": {
      "melt_temp": "DCS.BOPET.EXTRUDER.MELT_TEMP_SP",
      "extruder_speed": "DCS.BOPET.EXTRUDER.SPEED_SP",
      "casting_roll_temp": "DCS.BOPET.CASTING.ROLL_TEMP_SP",
      "md_stretch_ratio": "DCS.BOPET.MDO.STRETCH_RATIO_SP",
      "td_stretch_ratio": "DCS.BOPET.TDO.STRETCH_RATIO_SP",
      "td_oven_temp": "DCS.BOPET.TDO.OVEN_TEMP_SP",
      "line_speed": "DCS.BOPET.LINE.SPEED_SP",
      "winder_tension": "DCS.BOPET.WINDER.TENSION_SP"
    },
    "safety_limits": {
      "source": "line-server",
      "fallback_policy": "reject_when_unknown"
    }
  }
}
