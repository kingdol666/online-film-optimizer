{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["campaign_id", "experiment_id", "executed", "write_confirmed", "stable_window_before", "stable_window_after", "online_response", "decision", "waste_meter", "operator_note"],
  "properties": {
    "campaign_id": { "type": "string" },
    "experiment_id": { "type": "string" },
    "executed": { "type": "boolean" },
    "write_confirmed": { "type": "boolean" },
    "stable_window_before": { "type": "string" },
    "stable_window_after": { "type": "string" },
    "online_response": {
      "type": "object",
      "required": ["thickness_cv_change_pct", "birefringence_cv_change_pct"],
      "additionalProperties": { "type": "number" }
    },
    "decision": { "type": "string", "enum": ["effective", "ineffective", "worse", "rejected", "rolled_back"] },
    "waste_meter": { "type": "number", "minimum": 0 },
    "operator_note": { "type": "string" }
  }
}
