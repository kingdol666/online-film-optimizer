{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["iteration", "stage", "previous_stage", "transition_reason", "switch_trigger", "dominant_lever_confidence", "escalation_conditions", "evidence_digest"],
  "properties": {
    "iteration": { "type": "integer", "minimum": 1 },
    "stage": { "type": "string", "enum": ["explore", "exploit", "recover"] },
    "previous_stage": { "type": "string", "enum": ["explore", "exploit", "recover"] },
    "transition_reason": { "type": "string" },
    "switch_trigger": { "type": "string" },
    "dominant_lever_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "dominant_lever": {
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "escalation_conditions": {
      "type": "object",
      "required": ["enter_recover_on_consecutive_worse", "enter_recover_on_sensor_health", "enter_exploit_on_effective_count"],
      "properties": {
        "enter_recover_on_consecutive_worse": { "type": "integer" },
        "enter_recover_on_sensor_health": { "type": "array", "items": { "type": "string" } },
        "enter_exploit_on_effective_count": { "type": "integer" }
      }
    },
    "evidence_digest": {
      "type": "object",
      "required": ["history_signal", "quality_state", "current_loss"],
      "properties": {
        "history_signal": { "type": "string" },
        "quality_state": { "type": "string" },
        "current_loss": { "type": "number" }
      }
    }
  }
}
