{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["candidate_recipe_id", "release_status", "quality_evidence", "required_before_release", "recommended_use", "collaboration_summary"],
  "properties": {
    "candidate_recipe_id": { "type": "string" },
    "release_status": { "type": "string", "enum": ["candidate", "approved", "needs_more_validation", "rejected"] },
    "quality_evidence": { "type": "array", "items": { "type": "string" } },
    "required_before_release": { "type": "array", "items": { "type": "string" } },
    "recommended_use": { "type": "string" },
    "collaboration_summary": {
      "type": "object",
      "required": ["quality_role", "rd_role", "process_role"],
      "properties": {
        "quality_role": { "type": "string" },
        "rd_role": { "type": "string" },
        "process_role": { "type": "string" }
      }
    }
  }
}
