{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "protocol_version",
    "kind",
    "request_id",
    "action",
    "source",
    "line_id",
    "timestamp",
    "payload"
  ],
  "properties": {
    "protocol_version": { "const": "online-line-bridge.v1" },
    "kind": { "const": "request" },
    "request_id": { "type": "string", "minLength": 1 },
    "action": {
      "type": "string",
      "enum": [
        "line.reset",
        "line.compact_state",
        "line.snapshot",
        "line.online_quality",
        "line.writable_parameters",
        "line.run_until_stable",
        "line.safety_preview",
        "line.request_approval",
        "line.apply_proposal",
        "line.rollback_recipe",
        "line.save_candidate_recipe",
        "line.load_recipe_baseline",
        "line.historian_window",
        "line.database_query",
        "line.heartbeat"
      ]
    },
    "source": { "type": "string" },
    "line_id": { "type": "string" },
    "campaign_id": { "type": ["string", "null"] },
    "product_grade": { "type": ["string", "null"] },
    "timestamp": { "type": "string" },
    "timeout_ms": { "type": ["number", "null"], "minimum": 1 },
    "payload": { "type": "object" },
    "context": {
      "type": "object",
      "properties": {
        "goal_request_id": { "type": ["string", "null"] },
        "execution_mode": { "type": "string" },
        "provider": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
