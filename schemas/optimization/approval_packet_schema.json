{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["role", "iteration", "packet_type", "approval_status", "approval_required", "approval_source", "execution_mode", "control_mode", "proposal", "safety_gate_result", "guardrails"],
  "properties": {
    "role": { "type": "string" },
    "iteration": { "type": "integer", "minimum": 1 },
    "packet_type": { "type": "string" },
    "approval_status": { "type": "string", "enum": ["pending", "approved", "rejected", "expired"] },
    "approval_required": { "type": "boolean" },
    "approval_source": { "type": "string" },
    "approval_note": { "type": "string" },
    "approved_at": { "type": "string" },
    "execution_mode": { "type": "string" },
    "user_goal": { "type": "string" },
    "control_mode": { "type": "string", "enum": ["explore", "exploit", "recover"] },
    "proposal": { "type": "object" },
    "safety_gate_result": { "type": "object" },
    "guardrails": {
      "type": "object",
      "required": ["required_before_apply", "rollback_recipe", "stop_rules"],
      "properties": {
        "required_before_apply": { "type": "array", "items": { "type": "string" } },
        "rollback_recipe": { "type": "string" },
        "stop_rules": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
