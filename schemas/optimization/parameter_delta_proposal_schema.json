{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["campaign_id", "experiment_id", "source_plan", "setpoint_changes", "rollback_recipe", "expected_lag_minutes", "execution_intent"],
  "properties": {
    "campaign_id": { "type": "string" },
    "experiment_id": { "type": "string" },
    "source_plan": { "type": "string" },
    "setpoint_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tag", "current", "target", "delta", "ramp_limit_per_min"],
        "properties": {
          "tag": { "type": "string" },
          "current": { "type": "number" },
          "target": { "type": "number" },
          "delta": { "type": "number" },
          "ramp_limit_per_min": { "type": "number", "minimum": 0 },
          "execution_role": { "type": "string" },
          "expected_response": { "type": "string" }
        }
      }
    },
    "rollback_recipe": { "type": "string" },
    "expected_lag_minutes": { "type": "number", "minimum": 0 },
    "execution_intent": {
      "type": "object",
      "required": ["primary_objective", "primary_hypothesis", "risk_guardrails", "control_mode", "operator_message"],
      "properties": {
        "primary_objective": { "type": "string" },
        "primary_hypothesis": { "type": "string" },
        "risk_guardrails": { "type": "array", "items": { "type": "string" } },
        "control_mode": { "type": "string", "enum": ["explore", "exploit", "recover"] },
        "operator_message": { "type": "string" }
      }
    }
  }
}
