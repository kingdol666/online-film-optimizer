{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "protocol_version",
    "kind",
    "request_id",
    "action",
    "ok"
  ],
  "properties": {
    "protocol_version": { "const": "online-line-bridge.v1" },
    "kind": { "const": "response" },
    "request_id": { "type": "string", "minLength": 1 },
    "action": { "type": "string" },
    "line_id": { "type": ["string", "null"] },
    "ok": { "type": "boolean" },
    "data": {},
    "error": {
      "type": ["object", "string", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "timestamp": { "type": "string" },
    "meta": { "type": "object" }
  },
  "additionalProperties": true
}
