{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["quality_state", "primary_quality_gap", "affected_metrics", "suspected_process_regions", "evidence_level", "confidence", "recommended_next_action", "blocking_issues", "metric_evaluations", "process_risk_summary", "history_signal_summary", "decision_context", "strategy_recommendation"],
  "properties": {
    "quality_state": { "type": "string", "enum": ["PASS", "WARNING", "FAIL", "NEEDS_DATA"] },
    "primary_quality_gap": { "type": "string" },
    "affected_metrics": { "type": "array", "items": { "type": "string" } },
    "suspected_process_regions": { "type": "array", "items": { "type": "string" } },
    "evidence_level": { "type": "integer", "minimum": 1, "maximum": 7 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "recommended_next_action": { "type": "string" },
    "blocking_issues": { "type": "array", "items": { "type": "string" } },
    "response_assessment": { "type": "string" },
    "current_loss": { "type": "number" },
    "metric_evaluations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["metric", "actual", "gap", "normalized_gap", "within_spec"],
        "properties": {
          "metric": { "type": "string" },
          "actual": { "type": "number" },
          "target": { "type": "number" },
          "max": { "type": "number" },
          "tolerance": { "type": "number" },
          "gap": { "type": "number" },
          "normalized_gap": { "type": "number" },
          "within_spec": { "type": "boolean" }
        }
      }
    },
    "process_risk_summary": {
      "type": "object",
      "required": ["alarm_active", "line_state", "sensor_health", "history_risk", "execution_readiness"],
      "properties": {
        "alarm_active": { "type": "boolean" },
        "line_state": { "type": "string" },
        "sensor_health": { "type": "string" },
        "history_risk": { "type": "string" },
        "execution_readiness": { "type": "string" }
      }
    },
    "history_signal_summary": {
      "type": "object",
      "required": ["recent_iterations_considered", "effective_count", "worse_count", "ineffective_count", "summary"],
      "properties": {
        "recent_iterations_considered": { "type": "integer" },
        "effective_count": { "type": "integer" },
        "worse_count": { "type": "integer" },
        "ineffective_count": { "type": "integer" },
        "summary": { "type": "string" }
      }
    },
    "decision_context": {
      "type": "object",
      "required": ["quality_priority", "improvement_urgency", "history_signal", "response_assessment", "stage_recommendation"],
      "properties": {
        "quality_priority": { "type": "string" },
        "improvement_urgency": { "type": "string" },
        "history_signal": { "type": "string" },
        "response_assessment": { "type": "string" },
        "stage_recommendation": { "type": "string" }
      }
    },
    "strategy_recommendation": {
      "type": "object",
      "required": ["next_stage", "reason", "trigger"],
      "properties": {
        "next_stage": { "type": "string", "enum": ["explore", "exploit", "recover"] },
        "reason": { "type": "string" },
        "trigger": { "type": "string" }
      }
    }
  }
}
