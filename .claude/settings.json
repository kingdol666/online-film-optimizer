{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read(./**)",
      "Write(./workspace/optimization-tasks/**)",
      "Write(./runtime/**)"
    ],
    "ask": [
      "Bash(npm install*)",
      "Bash(rm *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git checkout --*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/mcp-inject-global.mjs",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/mcp-preflight.mjs",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "closed-loop-optimizer",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/hooks/mcp-inject-global.mjs",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/.claude/skills/closed-loop-optimizer/scripts/native-team-enforcer.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [],
    "PostToolUse": []
  }
}
